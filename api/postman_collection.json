{
  "info": {
    "_postman_id": "2aa4e7f8-1d8f-4f82-bc5b-6e0f8e1baf52",
    "name": "NRG Flight API (FastAPI) - Full Endpoint Test",
    "description": "End-to-end Postman collection for the NRG Flight API.\n\nImport the matching environment: api/postman_environment_local.json\nDocumentation: api/POSTMAN.md",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 - Init",
      "item": [
        {
          "name": "Health + Init run variables (departureDate, userEmail)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Compute departureDate = today's date (YYYY-MM-DD)",
                  "const now = new Date();",
                  "const yyyy = now.getFullYear();",
                  "const mm = String(now.getMonth() + 1).padStart(2, '0');",
                  "const dd = String(now.getDate()).padStart(2, '0');",
                  "pm.environment.set('departureDate', `${yyyy}-${mm}-${dd}`);",
                  "",
                  "// Randomize user email so the collection can be re-run without conflicts",
                  "pm.environment.set('userEmail', `user+${Date.now()}@example.com`);",
                  "",
                  "// Clear run-dependent variables",
                  "['aircraftId','flightId','flightNumber','gate','seatId','seatCode','bookingId'].forEach(k => pm.environment.unset(k));",
                  "['adminAccessToken','adminRefreshToken','userAccessToken','refreshToken','adminAccountId','userAccountId'].forEach(k => pm.environment.unset(k));",
                  "",
                  "// slotId default is set in environment; keep it if already present",
                  "if (!pm.environment.get('slotId')) { pm.environment.set('slotId', '0'); }"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('health returns 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('health has status field', function () { pm.expect(pm.response.json()).to.have.property('status'); });",
                  "pm.test('departureDate is set', function () { pm.expect(pm.environment.get('departureDate')).to.match(/\\d{4}-\\d{2}-\\d{2}/); });",
                  "pm.test('userEmail is set', function () { pm.expect(pm.environment.get('userEmail')).to.include('@'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "Auth - Register Admin (idempotent)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register admin returns 201 or 409', function () { pm.expect([201,409]).to.include(pm.response.code); });",
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('adminAccountId', data.id);",
                  "  pm.test('admin email matches', function () { pm.expect(data.email).to.eql(pm.environment.get('adminEmail')); });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\",\n  \"full_name\": \"{{adminFullName}}\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": "{{baseUrl}}/api/v1/auth/register"
          }
        },
        {
          "name": "Auth - Login Admin (stores adminAccessToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(200);",
                  "const data = pm.response.json();",
                  "pm.test('token_type is bearer', function () { pm.expect(data.token_type).to.eql('bearer'); });",
                  "pm.environment.set('adminAccessToken', data.access_token);",
                  "pm.test('adminAccessToken stored', function () { pm.expect(pm.environment.get('adminAccessToken')).to.be.a('string').and.not.empty; });",
                  "",
                  "// Capture refresh_token cookie (optional, for debugging)",
                  "const setCookie = pm.response.headers.get('Set-Cookie');",
                  "if (setCookie) {",
                  "  const match = setCookie.match(/refresh_token=([^;]+);/);",
                  "  if (match) pm.environment.set('adminRefreshToken', match[1]);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "Auth - Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register user returns 201 or 409', function () { pm.expect([201,409]).to.include(pm.response.code); });",
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('userAccountId', data.id);",
                  "  pm.test('user email matches', function () { pm.expect(data.email).to.eql(pm.environment.get('userEmail')); });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"full_name\": \"{{userFullName}}\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": "{{baseUrl}}/api/v1/auth/register"
          }
        },
        {
          "name": "Auth - Login User (stores userAccessToken + refreshToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(200);",
                  "const data = pm.response.json();",
                  "pm.test('token_type is bearer', function () { pm.expect(data.token_type).to.eql('bearer'); });",
                  "pm.environment.set('userAccessToken', data.access_token);",
                  "pm.test('userAccessToken stored', function () { pm.expect(pm.environment.get('userAccessToken')).to.be.a('string').and.not.empty; });",
                  "",
                  "// Capture refresh_token cookie (needed for /auth/refresh)",
                  "const setCookie = pm.response.headers.get('Set-Cookie');",
                  "pm.test('login sets refresh cookie', function () { pm.expect(setCookie).to.be.a('string'); });",
                  "if (setCookie) {",
                  "  const match = setCookie.match(/refresh_token=([^;]+);/);",
                  "  if (match) pm.environment.set('refreshToken', match[1]);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "Auth - Me (requires userAccessToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(200);",
                  "const data = pm.response.json();",
                  "pm.test('me email matches', function () { pm.expect(data.email).to.eql(pm.environment.get('userEmail')); });"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {"key": "token", "value": "{{userAccessToken}}", "type": "string"}
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/auth/me"
          }
        },
        {
          "name": "Auth - Refresh (rotates refresh cookie + updates userAccessToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(200);",
                  "const data = pm.response.json();",
                  "pm.environment.set('userAccessToken', data.access_token);",
                  "pm.test('refresh returns bearer token', function () { pm.expect(data.token_type).to.eql('bearer'); });",
                  "",
                  "// Rotate refresh cookie", 
                  "const setCookie = pm.response.headers.get('Set-Cookie');",
                  "if (setCookie) {",
                  "  const match = setCookie.match(/refresh_token=([^;]+);/);",
                  "  if (match) pm.environment.set('refreshToken', match[1]);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Cookie", "value": "refresh_token={{refreshToken}}"}
            ],
            "url": "{{baseUrl}}/api/v1/auth/refresh"
          }
        }
      ]
    },
    {
